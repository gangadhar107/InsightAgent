# InsightAgent configuration.
# Copy this file to .env and fill in your own values.
# Never commit your real .env (it is gitignored).

# --- PostgreSQL / Pagila connection ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pagila
DB_USER=postgres
DB_PASSWORD=

# --- Chat LLM (generation, self-check, routing, resolving, clarifying) ---
LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-5

# --- Embeddings (table retrieval) ---
EMBEDDING_PROVIDER=google
EMBEDDING_MODEL=gemini-embedding-2
EMBEDDING_API_KEY=
